{
  "ssg": "hugo",
  "mode": "hosted",
  "build": {
    "hugoVersion": "0.135.0",
    "rubyVersion": "3.4.8",
    "nodeVersion": "22",
    "denoVersion": "2.7.1",
    "build_command": "hugo -b /",
    "output_path": "public",
    "environment_variables": [
      {
        "key": "HUGO_CACHEDIR",
        "value": "/usr/local/__site/src/.hugo_cache/"
      },
      {
        "key": "HUGO_VERSION",
        "value": "0.135.0"
      }
    ],
    "preserved_paths": "resources/,.hugo_cache/"
  }
}